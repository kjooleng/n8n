    {
      "parameters": {
        "promptType": "define",
        "text": "={{ `Search for the latest news on these two topics and write ONE structured news brief for EACH topic.\\n\\nTopic 1: ${$json.topic1}\\nTopic 2: ${$json.topic2}\\n\\nFor EACH topic, write a brief using EXACTLY this format:\\n\\n---\\n**Headline:** [One punchy headline summarising the key development]\\n**Core Thesis:** [1-2 sentences: what happened and why it matters to investors]\\n**Key Insights:**\\n* [Specific data point or development]\\n* [Specific data point or development]\\n* [Specific data point or development]\\n**Key Definitions:** *[Term]* - [Brief definition relevant to the story]\\n**Direct Statements & Statistics:** [Direct quote or key statistic from a source]\\n**Macro Linkages:** [How this connects to Singapore or US markets]\\n**Source URL:** [URL of the most relevant article found]\\n---\\n\\nWrite both briefs one after the other. Do not add any other text outside the format.` }}",
        "options": {
          "systemMessage": "You are a senior financial news analyst writing for sophisticated investors. Use the searxng_web_search tool to find the latest news. IMPORTANT: Always write in the exact structured format specified. Be factual and precise.",
          "maxIterations": 2,
          "returnIntermediateSteps": false
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
