    {
      "parameters": {
        "jsCode": "\n// Collect all agent outputs and combine into the daily brief\nconst items = $input.all();\nlet brief = '';\n\nfor (const item of items) {\n  const output = item.json.output || '';\n  brief += output.trim() + '\\n\\n---\\n\\n';\n}\n\n// Remove trailing separator\nbrief = brief.replace(/\\n\\n---\\n\\n$/, '');\n\n// Add header\nconst today = new Date().toLocaleDateString('en-SG', { \n  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',\n  timeZone: 'Asia/Singapore'\n});\n\nconst finalBrief = `Daily Investor Brief — ${today}\\n\\n${brief.trim()}`;\n\n// Return single item - downstream nodes handle routing\nreturn [{ json: { output: finalBrief, charCount: finalBrief.length } }];\n"
      },
