      "parameters": {
        "jsCode": "const topics = [\n  { pair: 1, topic1: \"Singapore economy financial news today\", topic2: \"US Federal Reserve interest rates 2026\" },\n  { pair: 2, topic1: \"Singapore STI stock market today\", topic2: \"US S&P 500 Nasdaq market today\" },\n  { pair: 3, topic1: \"Singapore MAS monetary policy 2026\", topic2: \"US inflation CPI data 2026\" },\n  { pair: 4, topic1: \"China economy Singapore impact 2026\", topic2: \"Oil price commodities market today\" },\n  { pair: 5, topic1: \"Singapore property real estate market 2026\", topic2: \"US earnings corporate results 2026\" }\n];\nreturn topics.map(t => ({ json: t }));"
      },
